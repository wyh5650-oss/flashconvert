{
  "name": "flashconvert",
  "productName": "闪转",
  "version": "0.1.0",
  "description": "闪转 FlashConvert — 本地文件格式转换桌面应用",
  "main": "out/main/index.js",
  "author": "win96",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "smoke": "electron . --smoke-test",
    "icon": "node scripts/make-icon.mjs",
    "dist": "electron-vite build && electron-builder --win --publish never",
    "dist:mac": "electron-vite build && electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.flashconvert.app",
    "productName": "闪转",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**"
    ],
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**",
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/7zip-bin/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities",
      "artifactName": "FlashConvert-${version}-mac-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "闪转",
      "artifactName": "FlashConvert-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "FlashConvert-Portable-${version}.${ext}"
    }
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "electron-store": "^8.2.0",
    "ffmpeg-static": "^5.3.0",
    "heic-convert": "^2.1.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/heic-convert": "^2.1.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "framer-motion": "^12.42.2",
    "material-symbols": "^0.45.6",
    "png-to-ico": "^3.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "zustand": "^5.0.14"
  }
}
